generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH (unchanged)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(LEARNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  domains         Domain[]         @relation("CreatorDomains")
  enrollments     Enrollment[]
  submissions     Submission[]
  certificates    Certificate[]
  expenses        Expense[]        @relation("UserExpenses")
  incomes         Income[]         @relation("UserIncomes")
  createdInvoices Invoice[]        @relation("CreatedInvoices")
  lessonProgress  LessonProgress[]
}

enum Role {
  ADMIN
  CREATOR
  LEARNER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CORE COURSE / INTERNSHIP STRUCTURE
// ─────────────────────────────────────────────

/// Top-level internship track (e.g. "Frontend Development", "Python Internship")
model Domain {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String? @db.Text
  iconUrl     String?
  bannerUrl   String?
  creatorId   String
  published   Boolean @default(false)
  isFeatured  Boolean @default(false)

  /// Pricing
  priceINR Decimal? @db.Decimal(10, 2)
  priceMYR Decimal? @db.Decimal(10, 2)
  isFree   Boolean  @default(false)

  /// Duration options shown to learner at enrollment (stored as months)
  durationOptions Int[] /// e.g. [1, 3]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     User         @relation("CreatorDomains", fields: [creatorId], references: [id])
  sections    Section[]
  tasks       Task[]
  enrollments Enrollment[]
}

/// Ordered groupings of lessons within a domain (e.g. "Week 1: HTML Basics")
model Section {
  id          String   @id @default(cuid())
  domainId    String
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  domain  Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

/// Individual content item inside a section
model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  description String?    @db.Text
  contentType LessonType
  orderIndex  Int        @default(0)
  isFree      Boolean    @default(false) /// preview lesson visible before purchase

  /// For VIDEO_UPLOAD — S3/R2 key
  videoKey             String?
  videoDurationSeconds Int?

  /// For EXTERNAL_VIDEO — YouTube/Loom URL
  externalUrl String?

  /// For ARTICLE — raw MDX/markdown content
  articleContent String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

enum LessonType {
  VIDEO_UPLOAD
  EXTERNAL_VIDEO
  ARTICLE
}

// ─────────────────────────────────────────────
// TASKS (graded milestones per domain)
// ─────────────────────────────────────────────

/// Graded milestone — either a project submission or a quiz
model Task {
  id           String   @id @default(cuid())
  domainId     String
  title        String
  description  String?  @db.Text
  taskType     TaskType
  orderIndex   Int      @default(0)
  isRequired   Boolean  @default(true) /// must pass to get certificate
  passingScore Int? /// for QUIZ — minimum % to pass (e.g. 70)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  domain      Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  submissions Submission[]
}

enum TaskType {
  PROJECT /// learner submits a GitHub repo URL
  QUIZ /// MCQ quiz
}

/// A single MCQ question inside a quiz task
model QuizQuestion {
  id          String   @id @default(cuid())
  taskId      String
  question    String   @db.Text
  orderIndex  Int      @default(0)
  explanation String?  @db.Text /// shown after answer
  createdAt   DateTime @default(now())

  task    Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  options QuizOption[]
}

/// Answer options for a quiz question
model QuizOption {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  orderIndex Int     @default(0)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// ENROLLMENT, PROGRESS & CERTIFICATES
// ─────────────────────────────────────────────

model Enrollment {
  id             String        @id @default(cuid())
  userId         String
  domainId       String
  durationMonths Int /// 1 or 3
  startDate      DateTime      @default(now())
  endDate        DateTime?
  paymentStatus  PaymentStatus @default(PENDING)
  paymentRef     String? /// Razorpay / Stripe payment ID
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  domain         Domain           @relation(fields: [domainId], references: [id])
  submissions    Submission[]
  certificate    Certificate?
  invoices       Invoice[]
  lessonProgress LessonProgress[]

  @@unique([userId, domainId])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/// Tracks a learner's task submission for an enrollment
model Submission {
  id           String           @id @default(cuid())
  enrollmentId String
  taskId       String
  userId       String
  status       SubmissionStatus @default(PENDING)

  /// For PROJECT tasks
  repoUrl String?
  notes   String? @db.Text

  /// For QUIZ tasks
  quizScore   Int? /// percentage 0-100
  quizAnswers Json? /// { questionId: optionId } map

  reviewedAt  DateTime?
  reviewNotes String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  task       Task       @relation(fields: [taskId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([enrollmentId, taskId])
}

enum SubmissionStatus {
  PENDING
  PASSED
  FAILED
  NEEDS_REVISION
}

/// Certificate issued to a learner upon completing all required tasks
model Certificate {
  id               String   @id @default(cuid())
  enrollmentId     String   @unique
  userId           String
  verificationHash String   @unique @default(cuid()) /// public URL slug
  issueDate        DateTime @default(now())
  pdfUrl           String? /// S3/R2 URL of generated PDF

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────
// PERSONAL FINANCE (unchanged)
// ─────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String?
  date        DateTime
  amountINR   Decimal  @db.Decimal(10, 2)
  amountMYR   Decimal  @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("UserExpenses", fields: [createdById], references: [id])
}

model Income {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String?
  date        DateTime
  amountINR   Decimal  @db.Decimal(10, 2)
  amountMYR   Decimal  @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("UserIncomes", fields: [createdById], references: [id])
}

model Invoice {
  id                String        @id @default(cuid())
  invoiceNo         String        @unique
  type              InvoiceType   @default(STUDENT)
  status            InvoiceStatus @default(PAID)
  enrollmentId      String?       @unique
  buyerName         String
  buyerEmail        String
  courseTitle       String
  projectName       String?
  domain            String?
  notes             String?       @db.Text
  emailTemplate     String?       @db.Text
  emailSubject      String?
  recipients        String[]      @default([])
  amountINR         Decimal       @db.Decimal(10, 2)
  gstPercent        Int           @default(18)
  gstAmount         Decimal       @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  pdfUrl            String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  dueDate           DateTime?
  issuedAt          DateTime      @default(now())
  sentAt            DateTime?
  paidAt            DateTime?
  failedAt          DateTime?
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  enrollment Enrollment?   @relation(fields: [enrollmentId], references: [id])
  createdBy  User?         @relation("CreatedInvoices", fields: [createdById], references: [id])
  items      InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  name        String
  description String?  @db.Text
  quantity    Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}

enum InvoiceType {
  STUDENT
  PROJECT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  FAILED
}

model LessonProgress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  enrollmentId String
  completedAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, enrollmentId])
}
